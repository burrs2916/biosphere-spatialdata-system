{
  "identifier": "preview-window",
  "description": "Capabilities for preview windows (decorations: true)",
  "windows": ["preview-*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "opener:default",
    "dialog:default"
  ]
}
